    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.3",
    "artillery": "^2.0.4",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^2.1.0",
    "faker": "^5.5.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "mock-fs": "^5.2.0",
    "newman": "^6.1.0",
    "newman-reporter-htmlextra": "^1.23.1",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "npm-check-updates": "^16.14.11",
    "prettier": "^3.1.0",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
