  "engines": {
    "node": ">=18.0.0 <23.0.0",
    "npm": ">=9.0.0 <11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/redirector-pro"
  },
  "bugs": {
    "url": "https://github.com/yourusername/redirector-pro/issues"
  },
  "homepage": "https://github.com/yourusername/redirector-pro#readme",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/scripts/"
    ],
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/scripts/**",
      "!**/tests/**",
      "!**/public/**",
      "!**/logs/**",
      "!**/data/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "testTimeout": 30000,
    "verbose": true
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "nodemonConfig": {
    "watch": ["server.js", "src/", "scripts/"],
    "ignore": ["logs/*", "public/*", "tests/*", "data/*"],
    "ext": "js,json",
    "env": {
      "NODE_ENV": "development"
    },
    "exec": "node --expose-gc server.js"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "jest": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended",
      "airbnb-base",
      "plugin:jest/recommended",
      "plugin:security/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "script"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^next" }],
      "max-len": ["error", { "code": 120 }],
      "consistent-return": "off",
      "func-names": "off",
      "no-param-reassign": "off",
      "no-underscore-dangle": "off",
      "class-methods-use-this": "off",
      "import/no-extraneous-dependencies": ["error", { "devDependencies": ["**/tests/**/*.js", "**/scripts/**/*.js", "**/generate-secrets.js"] }]
    }
  },
  "overrides": {
    "jose": "^4.15.4"
  }
}
