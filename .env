# ────────────────────────────────────────────────
# Required - IPinfo token (for unlimited geo lookups)
# Get your free token at: https://ipinfo.io/account/token
# ────────────────────────────────────────────────
IPINFO_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────
# Optional - Override default target URL
# ────────────────────────────────────────────────
# TARGET_URL=https://example.com/your-real-destination

# ────────────────────────────────────────────────
# Optional - Country filtering (ISO 3166-1 alpha-2 codes, uppercase)
# Leave empty to allow all countries
# ────────────────────────────────────────────────
# ALLOWED_COUNTRIES=NG,US,CA,GB
# BLOCKED_COUNTRIES=RU,CN,KP

# ────────────────────────────────────────────────
# Optional - Change port if needed (Render usually sets PORT automatically)
# PORT=10000
